# Flow Guru Mobile - Environment Variables

# Production site origin (no trailing slash). Chat hits POST {origin}/api/trpc (same backend as the web app).
EXPO_PUBLIC_FLOW_GURU_API_URL=https://floguru.com

# Optional — only if you still use Supabase client features in the app.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Server secrets live on Vercel / hosting (DATABASE_URL, OPENAI_API_KEY, GOOGLE_MAPS_API_KEY, etc.), not in the Expo app.
